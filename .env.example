WEATHER_API_KEY=replace-with-weather-api-key
GOOGLE_API_KEY=replace-with-google-api-key
GOOGLE_STATICMAPS_MAPID=replace-with-google-staticmaps-map-id

# Compose publishes and targets the server port configured by the installer.
INKPLATE_SERVER_PORT=8080

# Local image name.
INKPLATE_IMAGE=inkplate10-weather-cal:local

# Local image metadata. bin/install_server populates these from .version.json.
INKPLATE_BUILD_DATE=unknown
INKPLATE_VCS_REF=unknown
INKPLATE_VERSION=local

# Optional, only when current_conditions.source is netatmo
NETATMO_CLIENT_ID=
NETATMO_CLIENT_SECRET=
NETATMO_REFRESH_TOKEN=
NETATMO_DEVICE_ID=
NETATMO_MODULE_ID=
NETATMO_WIND_MODULE_ID=
NETATMO_RAIN_MODULE_ID=
