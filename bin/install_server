#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Inkplate Weather Calendar server installer

This helper starts the interactive installer for the server component. It can
configure one of:

  - Docker Compose from this checkout
  - Podman Compose from this checkout
  - experimental Proxmox VE 9 OCI/LXC deployment
  - a native systemd service under /srv/inkplate

Native systemd installs must run as root or from a user that can elevate with
sudo, doas, or run0. The installer checks this before making system changes.

Usage:
  ./bin/install_server [--dry-run] [--mode docker|podman|proxmox|systemd]
  ./bin/install_server --dry-run --non-interactive --answers bin/install_server.answers.example.json

Useful first run:
  ./bin/install_server --dry-run

Run this command from the repository root.
EOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

if [ ! -f "server/server.py" ] || [ ! -f "docker-compose.yml" ]; then
  echo "ERROR: this does not look like the repository root." >&2
  echo >&2
  echo "Change into the cloned inkplate10-weather-cal directory, then run:" >&2
  echo "  ./bin/install_server" >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is required to run the installer, but it was not found." >&2
  echo >&2
  echo "On Debian/Ubuntu, install it with:" >&2
  echo "  sudo apt-get install python3" >&2
  exit 1
fi

echo "Starting the Inkplate Weather Calendar server installer."
echo "Tip: use './bin/install_server --dry-run' to preview actions first."
echo

exec python3 bin/install_server.py "$@"
